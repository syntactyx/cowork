{
  "name": "cowork",
  "displayName": "YoTypeScript",
  "description": "A Claude AI assistant that lives in your editor — ask questions, get code suggestions, and collaborate without leaving VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onCommand:cowork.ask"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cowork.ask",
        "title": "Ask Claude"
      },
      {
        "command": "cowork.clear",
        "title": "Cowork: Clear Chat"
      }
    ],
    "keybindings": [
    {
        "command": "cowork.ask",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
    }
]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1"
  }
}
