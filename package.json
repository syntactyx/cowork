{
  "name": "cowork",
  "displayName": "Cowork",
  "description": "A Claude AI assistant that lives in your editor — ask questions, get code suggestions, and collaborate without leaving VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "publisher": "your-publisher-id",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/cowork"
  },
  "keywords": [
    "claude",
    "ai",
    "assistant",
    "code",
    "copilot"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
"contributes": {
  "commands": [
    {
      "command": "cowork.ask",
      "title": "Ask Claude",
      "icon": "$(comment-discussion)"
    },
    {
      "command": "cowork.clear",
      "title": "Cowork: Clear Chat"
    },
    {
      "command": "cowork.askWithSelection",
      "title": "Ask Claude about this code"
    }
  ],
  "keybindings": [
    {
      "command": "cowork.ask",
      "key": "ctrl+shift+c",
      "mac": "cmd+shift+c"
    }
  ],
  "menus": {
    "editor/context": [
      {
        "command": "cowork.askWithSelection",
        "when": "editorTextFocus && editorHasSelection",
        "group": "1_modification"
      }
    ]
  }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1"
  }
}